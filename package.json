{
  "name": "@brain0pia/pi-ultrathink",
  "version": "0.3.1",
  "description": "Pi extension for /ultrathink review loops with conditional git commits",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brainopia/pi-ultrathink.git"
  },
  "homepage": "https://github.com/brainopia/pi-ultrathink",
  "bugs": {
    "url": "https://github.com/brainopia/pi-ultrathink/issues"
  },
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "ultrathink"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "demo": "tsx demo/runDemo.ts",
    "check": "npm run typecheck && npm run test"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.57.1",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "@sinclair/typebox": "^0.34.41",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
